{
  "name": "@velocity-bpa/n8n-nodes-ocean-protocol",
  "version": "1.0.0",
  "description": "n8n community node for Ocean Protocol - Decentralized Data Exchange Protocol",
  "license": "SEE LICENSE IN LICENSE.md",
  "homepage": "https://n8n.io",
  "author": {
    "name": "Velocity BPA",
    "email": "support@velocitybpa.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/velocity-bpa/n8n-nodes-ocean-protocol.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@9.1.4",
  "main": "dist/index.js",
  "files": [
    "dist/**/*"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/OceanProtocolApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/OceanProtocol/OceanProtocol.node.js"
    ]
  },
  "scripts": {
    "build": "tsc && gulp copy",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials",
    "lintfix": "eslint nodes credentials --fix",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "n8n-community-node-package",
    "ocean-protocol",
    "decentralized-data",
    "data-nft",
    "datatoken",
    "compute-to-data"
  ],
  "dependencies": {
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "@types/node": "^18.16.0",
    "@typescript-eslint/eslint-plugin": "^7.15.1",
    "@typescript-eslint/parser": "^7.15.1",
    "eslint": "^8.56.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.1",
    "gulp": "^4.0.2",
    "n8n-workflow": "1.57.0",
    "prettier": "^2.7.1",
    "typescript": "^4.8.4"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}